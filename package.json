{
  "name": "@preflight/cli",
  "module": "index.ts",
  "type": "module",
  "version": "0.1.0",
  "description": "Manage AI coding plans as first-class artifacts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikhilesh-payyavuala/preflight.git"
  },
  "keywords": ["ai", "coding", "plans", "cli", "agents"],
  "bin": {
    "pf": "./src/cli/index.ts"
  },
  "files": [
    "src/",
    "skills/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --hot src/cli/index.ts",
    "test": "bun test",
    "build": "bun build --compile src/cli/index.ts --outfile dist/pf",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/cli/index.ts --outfile dist/pf-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/cli/index.ts --outfile dist/pf-linux-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/cli/index.ts --outfile dist/pf-darwin-x64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/cli/index.ts --outfile dist/pf-darwin-arm64"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "marked": "^17.0.4",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "react-dom": "^18",
    "yaml": "^2.8.2"
  }
}
